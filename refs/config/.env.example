# HTB Metrics — copy to repo root:  cp refs/config/.env.example .env
# Load with:  python generate.py --from-env
# See docs/guides/configuration.md
#
# Priority with --from-env:  env vars  >  CLI flags  >  htb-metrics.yml  >  defaults
# Priority without --from-env:  CLI flags  >  env vars  >  htb-metrics.yml  >  defaults

# Required
HTB_PROFILE_ID=000000

# Optional HTB app token (use one; first match wins: API_TOKEN, TOKEN, BEARER)
# HTB_API_TOKEN=
# HTB_TOKEN=
# HTB_BEARER=

# Output
HTB_TEMPLATE=classic
HTB_OUTPUT_DIR=output

# Cache (.cache/{profile_id}/ holds JSON responses + avatar_b64.txt)
HTB_CACHE_DIR=.cache
HTB_CACHE_TTL=3600
HTB_NO_CACHE=false

# Template rendering (true | false | 1 | 0 | yes | no | on | off)
HTB_HIDE_IF_NULL=true
