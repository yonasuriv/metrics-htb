# HTB Metrics configuration
# Copy this file to htb-metrics.yml and fill in your profile_id.
# All values except profile_id are optional.

profile_id: 000000        # Required: your 6-digit HTB profile ID
template: classic         # classic | compact | profile-card | rank-card | season-card
                          # terminal | hacker-red | hacker-yellow | light | minimal
output_dir: output        # where PNGs are saved
cache_ttl: 3600           # seconds to cache API responses (0 = no cache)
hide_if_null: true        # hide template fields that have no data
cache_dir: .cache         # where to store cached API responses
